{
  "name": "ugc-campaign",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "api",
    "web",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "npm --workspace api run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm-run-all build:shared build:api build:web",
    "build:shared": "npm --workspace shared run build",
    "build:api": "npm --workspace api run build",
    "build:web": "npm --workspace web run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}